<UserControl x:Class="Monitoring_net9.Controls.MetricTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

    <Border Background="{Binding TileBrush, ElementName=Root}"
            CornerRadius="14"
            Padding="8">

        <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Title, ElementName=Root}"
                       Foreground="{Binding TitleBrush, ElementName=Root}"
                       FontSize="42"/>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal">

                <TextBlock Text="{Binding Value, ElementName=Root}"
                           Foreground="{Binding ValueBrush, ElementName=Root}"
                           FontSize="74"
                           FontWeight="Bold"/>

                <TextBlock Text="{Binding Unit, ElementName=Root}"
                           Foreground="{Binding UnitBrush, ElementName=Root}"
                           FontSize="46"
                           Margin="16,0,0,6"
                           VerticalAlignment="Bottom"/>

            </StackPanel>

        </Grid>

    </Border>
</UserControl>
