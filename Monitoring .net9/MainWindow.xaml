<Window x:Class="Monitoring_net9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Monitoring"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal"
        Background="#151515">

    <Grid Margin="30">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>


        <!-- COLONNE GAUCHE -->
        <Grid Grid.Column="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>

                <!-- HEURE -->
                <RowDefinition Height="Auto"/>

                <!-- DATE -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="50"/>

                <!-- TITRE -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="50"/>

                <!-- LIGNE 1 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="30"/>

                <!-- LIGNE 2 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="30"/>

                <!-- LIGNE 3 -->
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <!-- HEURE -->
            <TextBlock Grid.Row="0"
               Grid.ColumnSpan="3"
               x:Name="TimeText"
               FontSize="70"
               FontWeight="Bold"
               Foreground="White"/>

            <!-- DATE -->
            <TextBlock Grid.Row="1"
               Grid.ColumnSpan="3"
               x:Name="DateText"
               FontSize="50"
               Foreground="#AAAAAA"/>

            <!-- TITRE -->
            <TextBlock Grid.Row="3"
               Grid.ColumnSpan="3"
               Text="CPU / RAM"
               FontSize="50"
               FontWeight="Bold"
               Foreground="White"/>

            <!-- CPU Usage -->
            <Border Grid.Row="5"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>
                    <TextBlock Text="CPU Usage"
                       FontSize="50"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuUsageText"
                       FontSize="90"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- CPU Temp -->
            <Border Grid.Row="5"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>
                    <TextBlock Text="CPU Temp"
                       FontSize="50"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuTempText"
                               FontSize="90"
                               FontWeight="Bold"
                               Foreground="Red"/>
                </StackPanel>
            </Border>

            <!-- RAM -->
            <Border Grid.Row="7"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>
                    <TextBlock Text="RAM"
                       FontSize="50"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="RamUsageText"
                       FontSize="90"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- CPU Clock -->
            <Border Grid.Row="7"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>
                    <TextBlock Text="CPU Clock"
                       FontSize="50"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuClockText"
                       FontSize="90"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- CPU Power -->
            <Border Grid.Row="9"
            Grid.ColumnSpan="3"
            Background="#252525"
            CornerRadius="20"
            Padding="2">

                <StackPanel>
                    <TextBlock Text="CPU Power"
                       FontSize="50"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuPowerText"
                       FontSize="90"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- COLONNE DROITE -->

        <Grid Grid.Column="2">
            
            

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>

                <!-- TITRE -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="10"/>

                <!-- LIGNE 1 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="5"/>

                <!-- LIGNE 2 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="5"/>

                <!-- LIGNE 3 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="5"/>

                <!-- LIGNE 3 -->
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="GPU"
                       FontSize="50"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <!-- GPU Usage -->
            <Border Grid.Row="2"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>
                    <TextBlock Text="GPU Usage"
                       FontSize="50"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuUsageText"
                       FontSize="90"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- GPU Temp -->
            <Border Grid.Row="2"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>
                    <TextBlock Text="GPU Temp"
                               FontSize="50"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuTempText"
                               FontSize="90"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- GPU Clock -->
            <Border Grid.Row="4"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="10">

                <StackPanel>
                    <TextBlock Text="GPU Clock"
                               FontSize="50"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuClockText"
                               FontSize="82"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- VRAM -->
            <Border Grid.Row="4"
                    Grid.Column="2"
                    Background="#252525"
                    CornerRadius="20"
                    Padding="5">

                <StackPanel>
                    <TextBlock Text="VRAM"
                       FontSize="50"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuMemoryText"
                       FontSize="90"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="6"
                    Grid.Column="0"
                    Background="#252525"
                    CornerRadius="20"
                    Padding="5">

                <StackPanel>
                    <TextBlock Text="GPU Hotspot"
                               FontSize="50"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuHotspotText"
                               FontSize="90"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

        <!-- GPU Memory Junction -->
        <Border Grid.Row="6"
                Grid.Column="2"
                Background="#252525"
                CornerRadius="20"
                Padding="5">

                <StackPanel>
                    <TextBlock Text="Memory Junction"
                               FontSize="50"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuMemoryJunctionText"
                               FontSize="90"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- GPU Memory Junction -->
            <Border Grid.Row="8"
                Grid.Column="0"
                Background="#252525"
                CornerRadius="20"
                Padding="5">

                <StackPanel>
                    <TextBlock Text="GPU Power"
                               FontSize="50"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuPowerText"
                               FontSize="90"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>