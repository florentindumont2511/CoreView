<Window x:Class="Monitoring.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monitoring"
        Height="700"
        Width="500"
        Background="#202020">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <TextBlock Text="MONITORING PC"
                       FontSize="28"
                       Foreground="White"
                       FontWeight="Bold"
                       Margin="0,0,0,30"/>

            <Border Background="#2E2E2E"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,10">
                <TextBlock x:Name="CpuUsageText"
                           FontSize="22"
                           Foreground="White"/>
            </Border>

            <Border Background="#2E2E2E"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,10">
                <TextBlock x:Name="RamUsageText"
                           FontSize="22"
                           Foreground="White"/>
            </Border>

            <Border Background="#2E2E2E"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,10">
                <TextBlock x:Name="GpuUsageText"
                           FontSize="22"
                           Foreground="White"/>
            </Border>

            <Border Background="#2E2E2E"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,10">
                <TextBlock x:Name="GpuTempText"
                           FontSize="22"
                           Foreground="White"/>
            </Border>

            <Border Background="#2E2E2E"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,10">
                <TextBlock x:Name="GpuMemoryText"
                           FontSize="22"
                           Foreground="White"/>
            </Border>

        </StackPanel>

    </ScrollViewer>
</Window>