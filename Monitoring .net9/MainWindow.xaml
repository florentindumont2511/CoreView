<Window x:Class="Monitoring_net9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Monitoring"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="#151515">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>


        <!-- COLONNE GAUCHE -->
        <StackPanel Grid.Column="0">

            <!-- HEURE / DATE -->
            <StackPanel Margin="0,0,0,40">

                <TextBlock x:Name="TimeText"
                   FontSize="44"
                   FontWeight="Bold"
                   Foreground="White"/>

                <TextBlock x:Name="DateText"
                   FontSize="18"
                   Foreground="#AAAAAA"/>

            </StackPanel>

            <TextBlock Text="CPU / RAM"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,30"/>

            <!-- CPU Usage -->
            <Border Background="#252525"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,0,20">

                <StackPanel>
                    <TextBlock Text="CPU Usage"
                               FontSize="22"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuUsageText"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Background="#252525"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,0,20">

                <StackPanel>
                    <TextBlock Text="CPU Temperature"
                               FontSize="22"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuTempText"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- RAM -->
            <Border Background="#252525"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,0,20">

                <StackPanel>
                    <TextBlock Text="RAM Used"
                               FontSize="22"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="RamUsageText"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Background="#252525"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,0,20">

                <StackPanel>
                    <TextBlock Text="CPU Clock"
                               FontSize="22"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuClockText"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Background="#252525"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,0,20">

                <StackPanel>
                    <TextBlock Text="CPU Power"
                               FontSize="22"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="CpuPowerText"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- COLONNE DROITE -->

        <Grid Grid.Column="2">
            
            

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>

                <!-- TITRE -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="20"/>

                <!-- LIGNE 1 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="10"/>

                <!-- LIGNE 2 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="10"/>

                <!-- LIGNE 3 -->
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="GPU"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <!-- GPU Usage -->
            <Border Grid.Row="2"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="15">

                <StackPanel>
                    <TextBlock Text="GPU Usage"
                       FontSize="18"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuUsageText"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- GPU Temp -->
            <Border Grid.Row="2"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="15">

                <StackPanel>
                    <TextBlock Text="GPU Temp"
                               FontSize="18"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuTempText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- GPU Clock -->
            <Border Grid.Row="4"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="15">

                <StackPanel>
                    <TextBlock Text="GPU Clock"
                               FontSize="18"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuClockText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- VRAM -->
            <Border Grid.Row="4"
                    Grid.Column="2"
                    Background="#252525"
                    CornerRadius="20"
                    Padding="15">

                <StackPanel>
                    <TextBlock Text="VRAM"
                       FontSize="18"
                       Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuMemoryText"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"/>
                </StackPanel>
            </Border>
            <Border Grid.Row="6"
                    Grid.Column="0"
                    Background="#252525"
                    CornerRadius="20"
                    Padding="15">

                <StackPanel>
                    <TextBlock Text="GPU Hotspot"
                               FontSize="18"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuHotspotText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

        <!-- GPU Memory Junction -->
        <Border Grid.Row="6"
                Grid.Column="2"
                Background="#252525"
                CornerRadius="20"
                Padding="15">

                <StackPanel>
                    <TextBlock Text="Memory Junction"
                               FontSize="18"
                               Foreground="#AAAAAA"/>

                    <TextBlock x:Name="GpuMemoryJunctionText"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>