<Window x:Class="Monitoring_net9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monitoring"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal"
        Background="#151515">

    <Window.Resources>

        <!-- Couleurs -->
        <SolidColorBrush x:Key="LabelBrush" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="ValueBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="UnitBrush" Color="#B3B3B3"/>

        <!-- Labels -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8A8A8"/>
            <Setter Property="FontSize" Value="55"/>
        </Style>

        <!-- Valeurs -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="90"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Unités -->
        <Style x:Key="UnitStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C0C0C0"/>
            <Setter Property="FontSize" Value="60"/>
            <Setter Property="Margin" Value="25,0,0,7"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>

    </Window.Resources>

    <Grid Margin="30">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>


        <!-- COLONNE GAUCHE -->
        <Grid Grid.Column="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>

                <!-- HEURE -->
                <RowDefinition Height="Auto"/>

                <!-- DATE -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="50"/>

                <!-- TITRE -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="50"/>

                <!-- LIGNE 1 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="30"/>

                <!-- LIGNE 2 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="30"/>

                <!-- LIGNE 3 -->
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <!-- HEURE -->
            <TextBlock Grid.Row="0"
               Grid.ColumnSpan="3"
               x:Name="TimeText"
               FontSize="70"
               FontWeight="Bold"
               Foreground="White"/>

            <!-- DATE -->
            <TextBlock Grid.Row="1"
               Grid.ColumnSpan="3"
               x:Name="DateText"
               FontSize="50"
               Foreground="#AAAAAA"/>

            <!-- TITRE -->
            <TextBlock Grid.Row="3"
               Grid.ColumnSpan="3"
               Text="CPU / RAM"
               FontSize="70"
               FontWeight="Bold"
               Foreground="White"/>

            <!-- CPU Usage -->
            <Border Grid.Row="5"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="CPU Usage"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="CpuUsageText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="%"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- CPU Temp -->
            <Border Grid.Row="5"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="CPU Temp"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="CpuTempText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="°C"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- RAM -->
            <Border Grid.Row="7"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="RAM"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="RamUsageText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="GB"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- CPU Clock -->
            <Border Grid.Row="7"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="CPU Clock"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="CpuClockText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="GHz"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- CPU Power -->
            <Border Grid.Row="9"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="2">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="CPU Power"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="CpuPowerText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="W"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- CPU Tension -->
            <Border Grid.Row="9"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="2">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="CPU Tension"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="CpuTensionText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="V"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>


        <!-- COLONNE DROITE -->

        <Grid Grid.Column="2">




            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>



            <Grid.RowDefinitions>

                <!-- TITRE -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="10"/>

                <!-- LIGNE 1 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="5"/>

                <!-- LIGNE 2 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="5"/>

                <!-- LIGNE 3 -->
                <RowDefinition Height="Auto"/>

                <!-- ESPACE -->
                <RowDefinition Height="5"/>

                <!-- LIGNE 3 -->
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <Button x:Name="SettingsButton"
                    Content="⚙"
                    Width="70"
                    Height="70"
                    FontSize="46"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="Transparent"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,10,0"
                    Click="SettingsButton_Click"
                    RenderTransformOrigin="3.4,0.549"
                    Grid.Column="2"
                    Panel.ZIndex="999"/>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="GPU"
                       FontSize="70"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <!-- GPU Usage -->
            <Border Grid.Row="2"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="GPU Usage"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuUsageText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="%"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- GPU Temp -->
            <Border Grid.Row="2"
            Grid.Column="2"
            Background="#252525"
            CornerRadius="20"
            Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="GPU Temp"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuTempText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="°C"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- GPU Clock -->
            <Border Grid.Row="4"
            Grid.Column="0"
            Background="#252525"
            CornerRadius="20"
            Padding="10">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="GPU Clock"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuClockText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="MHz"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- VRAM -->
            <Border Grid.Row="4"
                    Grid.Column="2"
                    Background="#252525"
                    CornerRadius="20"
                    Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="VRAM"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuMemoryText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="GB"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>


            <Border Grid.Row="6"
                    Grid.Column="0"
                    Background="#252525"
                    CornerRadius="20"
                    Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="GPU Hotspot"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuHotspotText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="°C"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- GPU Memory Junction -->
            <Border Grid.Row="6"
                Grid.Column="2"
                Background="#252525"
                CornerRadius="20"
                Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="Memory Junction"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuMemoryJunctionText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="°C"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- GPU Power -->
            <Border Grid.Row="8"
                Grid.Column="0"
                Background="#252525"
                CornerRadius="20"
                Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="GPU Power"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuPowerText"
                            Style="{StaticResource ValueStyle}"/>

                        <TextBlock Text="W"
                            Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!-- GPU Tension -->
            <Border Grid.Row="8"
                Grid.Column="2"
                Background="#252525"
                CornerRadius="20"
                Padding="5">

                <StackPanel>

                    <!-- LABEL -->
                    <TextBlock Text="GPU Tension"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- VALEUR + UNITE -->
                    <StackPanel Orientation="Horizontal">

                        <TextBlock x:Name="GpuTensionText"
                           Style="{StaticResource ValueStyle}"/>

                        <TextBlock x:Name="GpuTensionUnitText"
                           Style="{StaticResource UnitStyle}"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>
    </Grid>


</Window>
    
    
