<Window x:Class="Monitoring_net9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Monitoring_net9.Controls"
        Title="Monitoring"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal"
        Background="{Binding DashboardBrush}">

    <Grid Margin="30">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding DashboardScale}"
                            ScaleY="{Binding DashboardScale}"/>
        </Grid.LayoutTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="{Binding CurrentTime}"
                       FontSize="70"
                       FontWeight="Bold"
                       Foreground="{Binding HeaderBrush}"/>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="3"
                       Text="{Binding CurrentDate}"
                       FontSize="50"
                       Foreground="{Binding SecondaryTextBrush}"/>

            <TextBlock Grid.Row="3"
                       Grid.ColumnSpan="3"
                       Text="CPU / RAM"
                       FontSize="70"
                       FontWeight="Bold"
                       Foreground="{Binding HeaderBrush}"/>

            <controls:MetricTile Grid.Row="5"
                                 Grid.Column="0"
                                 Title="CPU Usage"
                                 Value="{Binding CpuUsage}"
                                 Unit="%"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="5"
                                 Grid.Column="2"
                                 Title="CPU Temp"
                                 Value="{Binding CpuTemperature}"
                                 Unit="&#176;C"
                                 ValueBrush="{Binding CpuTemperatureBrush}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="7"
                                 Grid.Column="0"
                                 Title="RAM"
                                 Value="{Binding RamUsage}"
                                 Unit="GB"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="7"
                                 Grid.Column="2"
                                 Title="CPU Clock"
                                 Value="{Binding CpuClock}"
                                 Unit="GHz"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="9"
                                 Grid.Column="0"
                                 Title="CPU Power"
                                 Value="{Binding CpuPower}"
                                 Unit="W"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="9"
                                 Grid.Column="2"
                                 Title="CPU Tension"
                                 Value="{Binding CpuTension}"
                                 Unit="V"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

        </Grid>

        <Grid Grid.Column="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button x:Name="SettingsButton"
                    Content="&#9881;"
                    Width="70"
                    Height="70"
                    FontSize="46"
                    Background="Transparent"
                    Foreground="{Binding HeaderBrush}"
                    BorderBrush="Transparent"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,10,0"
                    Click="SettingsButton_Click"
                    RenderTransformOrigin="3.4,0.549"
                    Grid.Column="2"
                    Panel.ZIndex="999"/>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="GPU"
                       FontSize="70"
                       FontWeight="Bold"
                       Foreground="{Binding HeaderBrush}"
                       Margin="0,0,0,10"/>

            <controls:MetricTile Grid.Row="2"
                                 Grid.Column="0"
                                 Title="GPU Usage"
                                 Value="{Binding GpuUsage}"
                                 Unit="%"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="2"
                                 Grid.Column="2"
                                 Title="GPU Temp"
                                 Value="{Binding GpuTemperature}"
                                 Unit="&#176;C"
                                 ValueBrush="{Binding GpuTemperatureBrush}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="4"
                                 Grid.Column="0"
                                 Title="GPU Clock"
                                 Value="{Binding GpuClock}"
                                 Unit="MHz"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="4"
                                 Grid.Column="2"
                                 Title="VRAM"
                                 Value="{Binding GpuMemory}"
                                 Unit="GB"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="6"
                                 Grid.Column="0"
                                 Title="GPU Hotspot"
                                 Value="{Binding GpuHotspot}"
                                 Unit="&#176;C"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="6"
                                 Grid.Column="2"
                                 Title="Memory Junction"
                                 Value="{Binding GpuMemoryJunction}"
                                 Unit="&#176;C"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="8"
                                 Grid.Column="0"
                                 Title="GPU Power"
                                 Value="{Binding GpuPower}"
                                 Unit="W"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="8"
                                 Grid.Column="2"
                                 Title="GPU Tension"
                                 Value="{Binding GpuTension}"
                                 Unit="{Binding GpuTensionUnit}"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <Grid Grid.Row="10"
                  Grid.ColumnSpan="3"
                  Visibility="{Binding MiniGraphsVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{Binding TileBrush}"
                        CornerRadius="12"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="CPU 60s"
                                   Foreground="{Binding TitleBrush}"
                                   FontSize="18"/>
                        <Grid Height="52">
                            <Polyline Points="{Binding CpuUsageHistoryPoints}"
                                      Stroke="{Binding ChartLineBrush}"
                                      StrokeThickness="3"/>
                            <Polyline Points="{Binding CpuTemperatureHistoryPoints}"
                                      Stroke="{Binding CpuTemperatureBrush}"
                                      StrokeThickness="2"
                                      Opacity="0.75"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{Binding TileBrush}"
                        CornerRadius="12"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="GPU 60s"
                                   Foreground="{Binding TitleBrush}"
                                   FontSize="18"/>
                        <Grid Height="52">
                            <Polyline Points="{Binding GpuUsageHistoryPoints}"
                                      Stroke="{Binding ChartLineBrush}"
                                      StrokeThickness="3"/>
                            <Polyline Points="{Binding GpuTemperatureHistoryPoints}"
                                      Stroke="{Binding GpuTemperatureBrush}"
                                      StrokeThickness="2"
                                      Opacity="0.75"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>

</Window>
