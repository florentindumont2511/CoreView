<Window x:Class="Monitoring_net9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Monitoring_net9.Controls"
        Title="Monitoring"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal"
        Background="{Binding DashboardBrush}">

    <Grid Margin="24">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding DashboardScale}"
                            ScaleY="{Binding DashboardScale}"/>
        </Grid.LayoutTransform>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" />
            <ColumnDefinition Width="30" />
            <ColumnDefinition Width="1.4*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="1.7*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="{Binding CurrentTime}"
                       FontSize="62"
                       FontWeight="Bold"
                       Foreground="{Binding HeaderBrush}"/>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="3"
                       Text="{Binding CurrentDate}"
                       FontSize="52"
                       Foreground="{Binding SecondaryTextBrush}"/>

            <TextBlock Grid.Row="3"
                       Grid.ColumnSpan="3"
                       Text="CPU / RAM"
                       FontSize="44"
                       FontWeight="Bold"
                       Foreground="{Binding HeaderBrush}"/>

            <controls:MetricTile Grid.Row="5"
                                 Grid.Column="0"
                                 Title="CPU Usage"
                                 Value="{Binding CpuUsage}"
                                 Unit="%"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="5"
                                 Grid.Column="2"
                                 Title="CPU Temp"
                                 Value="{Binding CpuTemperature}"
                                 Unit="&#176;C"
                                 ValueBrush="{Binding CpuTemperatureBrush}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="7"
                                 Grid.Column="0"
                                 Title="RAM"
                                 Value="{Binding RamUsage}"
                                 Unit="GB"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="7"
                                 Grid.Column="2"
                                 Title="CPU Clock"
                                 Value="{Binding CpuClock}"
                                 Unit="GHz"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="9"
                                 Grid.Column="0"
                                 Title="CPU Power"
                                 Value="{Binding CpuPower}"
                                 Unit="W"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="9"
                                 Grid.Column="2"
                                 Title="CPU Tension"
                                 Value="{Binding CpuTension}"
                                 Unit="V"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <Border Grid.Row="11"
                    Grid.ColumnSpan="3"
                    Background="{Binding TileBrush}"
                    CornerRadius="10"
                    Padding="14"
                    Visibility="{Binding MiniGraphsVisibility}">
                <StackPanel>
                    <TextBlock Foreground="{Binding TitleBrush}"
                               FontSize="44"
                               Margin="0,0,0,4">
                        <Run Text="CPU "/>
                        <Run Text="{Binding HistoryDurationLabel, Mode=OneWay}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Line X1="0"
                              X2="28"
                              Y1="8"
                              Y2="8"
                              Stroke="{Binding ChartLineBrush}"
                              StrokeThickness="4"/>
                        <TextBlock Text="Usage"
                                   Foreground="{Binding UnitBrush}"
                                   FontSize="17"
                                   Margin="8,0,18,0"/>
                        <Line X1="0"
                              X2="28"
                              Y1="8"
                              Y2="8"
                              Stroke="{Binding CpuTemperatureBrush}"
                              StrokeThickness="3"/>
                        <TextBlock Text="Temp"
                                   Foreground="{Binding UnitBrush}"
                                   FontSize="17"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <Viewbox Stretch="Fill"
                             Height="170">
                        <Grid Width="320"
                              Height="170">
                            <Line X1="0"
                                  X2="320"
                                  Y1="0"
                                  Y2="0"
                                  Stroke="{Binding ChartGridBrush}"
                                  StrokeThickness="1"/>
                            <Line X1="0"
                                  X2="320"
                                  Y1="85"
                                  Y2="85"
                                  Stroke="{Binding ChartGridBrush}"
                                  StrokeThickness="1"/>
                            <Line X1="0"
                                  X2="320"
                                  Y1="170"
                                  Y2="170"
                                  Stroke="{Binding ChartGridBrush}"
                                  StrokeThickness="1"/>
                            <TextBlock Text="100%"
                                       Foreground="{Binding UnitBrush}"
                                       FontSize="12"
                                       Opacity="0.75"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding CpuTemperatureAxisLabel}"
                                       Foreground="{Binding UnitBrush}"
                                       FontSize="12"
                                       Opacity="0.75"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"/>
                            <TextBlock Text="0"
                                       Foreground="{Binding UnitBrush}"
                                       FontSize="12"
                                       Opacity="0.75"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"/>
                            <Polygon Points="{Binding CpuUsageAreaPoints}"
                                     Fill="{Binding ChartAreaBrush}"/>
                            <Polyline Points="{Binding CpuUsageHistoryPoints}"
                                      Stroke="{Binding ChartLineBrush}"
                                      StrokeThickness="4"/>
                            <Polyline Points="{Binding CpuTemperatureHistoryPoints}"
                                      Stroke="{Binding CpuTemperatureBrush}"
                                      StrokeThickness="3"
                                      Opacity="0.75"/>
                        </Grid>
                    </Viewbox>
                </StackPanel>
            </Border>

        </Grid>

        <Grid Grid.Column="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="1.7*"/>
            </Grid.RowDefinitions>

            <Button x:Name="SettingsButton"
                    Content="&#9881;"
                    Width="72"
                    Height="72"
                    FontSize="48"
                    Background="Transparent"
                    Foreground="{Binding HeaderBrush}"
                    BorderBrush="Transparent"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,10,0"
                    Click="SettingsButton_Click"
                    RenderTransformOrigin="3.4,0.549"
                    Grid.Column="2"
                    Panel.ZIndex="999"/>

            <TextBlock Grid.Column="2"
                       Text="{Binding HwInfoStatus}"
                       Foreground="{Binding HwInfoStatusBrush}"
                       FontSize="26"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,84,12,0"
                       Panel.ZIndex="999"/>

            <TextBlock Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="GPU"
                       FontSize="52"
                       FontWeight="Bold"
                       Foreground="{Binding HeaderBrush}"
                       Margin="0,0,0,10"/>

            <controls:MetricTile Grid.Row="2"
                                 Grid.Column="0"
                                 Title="GPU Usage"
                                 Value="{Binding GpuUsage}"
                                 Unit="%"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="2"
                                 Grid.Column="2"
                                 Title="GPU Temp"
                                 Value="{Binding GpuTemperature}"
                                 Unit="&#176;C"
                                 ValueBrush="{Binding GpuTemperatureBrush}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="4"
                                 Grid.Column="0"
                                 Title="GPU Clock"
                                 Value="{Binding GpuClock}"
                                 Unit="MHz"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="4"
                                 Grid.Column="2"
                                 Title="VRAM"
                                 Value="{Binding GpuMemory}"
                                 Unit="GB"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="6"
                                 Grid.Column="0"
                                 Title="GPU Hotspot"
                                 Value="{Binding GpuHotspot}"
                                 Unit="&#176;C"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="6"
                                 Grid.Column="2"
                                 Title="Memory Junction"
                                 Value="{Binding GpuMemoryJunction}"
                                 Unit="&#176;C"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="8"
                                 Grid.Column="0"
                                 Title="GPU Power"
                                 Value="{Binding GpuPower}"
                                 Unit="W"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <controls:MetricTile Grid.Row="8"
                                 Grid.Column="2"
                                 Title="GPU Tension"
                                 Value="{Binding GpuTension}"
                                 Unit="{Binding GpuTensionUnit}"
                                 Visibility="{Binding AdvancedSensorsVisibility}"
                                 TileBrush="{Binding TileBrush}"
                                 TitleBrush="{Binding TitleBrush}"
                                 UnitBrush="{Binding UnitBrush}"/>

            <Border Grid.Row="10"
                    Grid.ColumnSpan="3"
                    Background="{Binding TileBrush}"
                    CornerRadius="10"
                    Padding="14"
                    Visibility="{Binding MiniGraphsVisibility}">
                <StackPanel>
                    <TextBlock Foreground="{Binding TitleBrush}"
                               FontSize="44"
                               Margin="0,0,0,4">
                        <Run Text="GPU "/>
                        <Run Text="{Binding HistoryDurationLabel, Mode=OneWay}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Line X1="0"
                              X2="28"
                              Y1="8"
                              Y2="8"
                              Stroke="{Binding ChartLineBrush}"
                              StrokeThickness="4"/>
                        <TextBlock Text="Usage"
                                   Foreground="{Binding UnitBrush}"
                                   FontSize="17"
                                   Margin="8,0,18,0"/>
                        <Line X1="0"
                              X2="28"
                              Y1="8"
                              Y2="8"
                              Stroke="{Binding GpuTemperatureBrush}"
                              StrokeThickness="3"/>
                        <TextBlock Text="Temp"
                                   Foreground="{Binding UnitBrush}"
                                   FontSize="17"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                    <Viewbox Stretch="Fill"
                             Height="170">
                        <Grid Width="320"
                              Height="170">
                            <Line X1="0"
                                  X2="320"
                                  Y1="0"
                                  Y2="0"
                                  Stroke="{Binding ChartGridBrush}"
                                  StrokeThickness="1"/>
                            <Line X1="0"
                                  X2="320"
                                  Y1="85"
                                  Y2="85"
                                  Stroke="{Binding ChartGridBrush}"
                                  StrokeThickness="1"/>
                            <Line X1="0"
                                  X2="320"
                                  Y1="170"
                                  Y2="170"
                                  Stroke="{Binding ChartGridBrush}"
                                  StrokeThickness="1"/>
                            <TextBlock Text="100%"
                                       Foreground="{Binding UnitBrush}"
                                       FontSize="12"
                                       Opacity="0.75"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"/>
                            <TextBlock Text="{Binding GpuTemperatureAxisLabel}"
                                       Foreground="{Binding UnitBrush}"
                                       FontSize="12"
                                       Opacity="0.75"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"/>
                            <TextBlock Text="0"
                                       Foreground="{Binding UnitBrush}"
                                       FontSize="12"
                                       Opacity="0.75"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"/>
                            <Polygon Points="{Binding GpuUsageAreaPoints}"
                                     Fill="{Binding ChartAreaBrush}"/>
                            <Polyline Points="{Binding GpuUsageHistoryPoints}"
                                      Stroke="{Binding ChartLineBrush}"
                                      StrokeThickness="4"/>
                            <Polyline Points="{Binding GpuTemperatureHistoryPoints}"
                                      Stroke="{Binding GpuTemperatureBrush}"
                                      StrokeThickness="3"
                                      Opacity="0.75"/>
                        </Grid>
                    </Viewbox>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>

</Window>
