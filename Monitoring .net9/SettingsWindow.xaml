<Window x:Class="Monitoring_.net9.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monitoring_.net9"
        mc:Ignorable="d"
        Title="Options"
        Height="500"
        Width="700"
        Background="#181818"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="Options CoreView"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,20"/>

            <CheckBox Content="Lancer au démarrage"
                      Foreground="White"
                      FontSize="18"
                      Margin="0,10"/>

            <CheckBox Content="Toujours au premier plan"
                      Foreground="White"
                      FontSize="18"
                      Margin="0,10"/>

            <CheckBox Content="Masquer la souris"
                      Foreground="White"
                      FontSize="18"
                      Margin="0,10"/>

        </StackPanel>

    </Grid>
</Window>
