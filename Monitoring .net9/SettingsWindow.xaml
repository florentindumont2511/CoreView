<Window x:Class="Monitoring_net9.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Monitoring_net9"
        mc:Ignorable="d"
        Title="Options"
        Height="900"
        Width="920"
        Background="#181818"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="Options CoreView"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,26"/>

            <TextBlock Text="S&#233;lectionner l'&#233;cran"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <ComboBox x:Name="ScreenComboBox"
                      Width="420"
                      Height="48"
                      FontSize="22"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,24"/>

            <TextBlock Text="Chemin HWiNFO"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="HwInfoPathTextBox"
                         Grid.Column="0"
                         Height="48"
                         FontSize="20"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="Parcourir"
                        Height="48"
                        FontSize="20"
                        Click="BrowseHwInfoButton_Click"/>
            </Grid>

            <TextBlock Text="Apparence"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,24">
                <ComboBox x:Name="ThemeComboBox"
                          Width="220"
                          Height="48"
                          FontSize="20"
                          Margin="0,0,28,0">
                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Contrast"/>
                </ComboBox>

                <TextBlock Text="Taille"
                           Foreground="White"
                           FontSize="22"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>

                <TextBox x:Name="DashboardScaleTextBox"
                         Width="90"
                         Height="48"
                         FontSize="20"
                         VerticalContentAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Seuils temp&#233;rature"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CPU"
                           Foreground="White"
                           FontSize="22"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         x:Name="CpuWarningTextBox"
                         Height="48"
                         FontSize="20"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBox Grid.Column="2"
                         x:Name="CpuDangerTextBox"
                         Height="48"
                         FontSize="20"
                         VerticalContentAlignment="Center"
                         Margin="0,0,20,0"/>
                <TextBlock Grid.Column="3"
                           Text="GPU"
                           Foreground="White"
                           FontSize="22"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="4"
                         x:Name="GpuWarningTextBox"
                         Height="48"
                         FontSize="20"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBox Grid.Column="5"
                         x:Name="GpuDangerTextBox"
                         Height="48"
                         FontSize="20"
                         VerticalContentAlignment="Center"/>
            </Grid>

            <CheckBox x:Name="ShowAdvancedSensorsCheckBox"
                      Content="Afficher les capteurs avanc&#233;s"
                      Foreground="White"
                      FontSize="22"
                      Margin="0,0,0,14"/>

            <CheckBox x:Name="ShowMiniGraphsCheckBox"
                      Content="Afficher les mini-graphes"
                      Foreground="White"
                      FontSize="22"
                      Margin="0,0,0,14"/>

            <TextBlock Text="Dur&#233;e historique"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,8,0,10"/>

            <ComboBox x:Name="HistoryDurationComboBox"
                      Width="220"
                      Height="48"
                      FontSize="20"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,24">
                <ComboBoxItem Content="30s" Tag="30"/>
                <ComboBoxItem Content="60s" Tag="60"/>
                <ComboBoxItem Content="2min" Tag="120"/>
                <ComboBoxItem Content="5min" Tag="300"/>
            </ComboBox>

            <CheckBox x:Name="StartupCheckBox"
                      Content="Lancer au d&#233;marrage"
                      Foreground="White"
                      FontSize="22"
                      Checked="StartupCheckBox_Checked"
                      Unchecked="StartupCheckBox_Unchecked"
                      Margin="0,0,0,14"/>

            <CheckBox x:Name="FullscreenCheckBox"
                      Content="Mode plein &#233;cran"
                      Foreground="White"
                      FontSize="22"
                      Margin="0,0,0,28"/>

            <StackPanel Orientation="Horizontal">
                <Button Content="Sauvegarder"
                        Width="260"
                        Height="64"
                        FontSize="22"
                        Margin="0,0,18,0"
                        Click="SaveButton_Click"/>

                <Button Content="R&#233;initialiser"
                        Width="260"
                        Height="64"
                        FontSize="22"
                        Click="ResetButton_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
